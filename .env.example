# Login password
FILE_SERVER_PASSWORD=changeme

# Root directory to serve
FILE_ROOT=/share/Public

# JWT signing secret (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-this-to-a-random-string

# Server port
PORT=3000

# Separate password required for deleting files (leave empty to allow delete without extra auth)
DELETE_PASSWORD=

# Origin URL for production (fixes SvelteKit CSRF)
ORIGIN=http://192.168.1.103:3000

# Cloudflare tunnel token (optional, for Docker deployment)
# TUNNEL_TOKEN=your-cloudflare-tunnel-token
